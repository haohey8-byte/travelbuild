generator client {
  provider      = "prisma-client-js"
  // 容器运行环境为 Debian bookworm (OpenSSL 3.0)，显式声明该引擎，避免 generate 时错判为 1.1.x
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 角色：一手 PandaKing / 境外旅行社 / 省地接社
enum Role {
  pandaking
  agency
  provincial
}

// 机构内层级：管理员（可被授权邀请员工）/ 员工
// - 一手 PandaKing 视为管理员（枢纽，可见全部）
// - 境外旅行社 / 省地接社 各自有 admin 与 staff
enum RoleLevel {
  admin
  staff
}

// 机构（境外旅行社 / 省地接社）
model Agency {
  id         String        @id
  name       String
  role       Role          // agency | provincial
  contact    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  users      User[]
  routes     Route[]       @relation("RouteAgency")
  provincialRoutes Route[] @relation("RouteProvincial")
  inquiries  CostInquiry[] @relation("CostInquiryProvincial")
}

enum CaseStatus {
  draft
  published
  offline
}

// 用户：管理员=手机号+密码（bcrypt）；协作者=链接即凭证（零账号，不在此表）
model User {
  id            String    @id @default(uuid())
  name          String                  // 显示名称（必填；多管理员靠此区分）
  phone         String   @unique        // 登录键（手机号，必填唯一）；存量行回填 legacy_<id>
  email         String?                 // 可选联系邮箱（非登录键，保持可空、非唯一）
  password      String?                 // bcrypt 哈希；仅 pandaking 管理员持有
  mustChangePwd Boolean   @default(true) // 种子/重置后强制改密
  role          Role      @default(pandaking)
  agencyId      String? // 归属机构 ID（境外旅行社 / 省地接社的 org id；一手为 null）
  agency        Agency?   @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  level         RoleLevel @default(admin) // pandaking 默认 admin
  parentId      String? // 邀请人（上级），用于层级与审计
  openid        String?  @unique         // 保留 nullable，Phase 2 回填
  disabled      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  invites       Invite[]
  createdRoutes Route[] @relation("RouteCreatedBy")
}

// 邀请（两层级：一手邀请机构管理员 → 管理员/一手邀请机构员工）
// - agencyId：受邀者归属的机构 org id（境外旅行社 / 省地接社）
// - level：admin=机构管理员（首邀），staff=机构员工（由管理员或一手再邀）
// - parentId：邀请人用户 id（层级/审计）
model Invite {
  id         String    @id @default(uuid())
  token      String    @unique
  role       Role
  agencyId   String? // 受邀者归属机构（agency/provincial 必填；手为 null）
  level      RoleLevel @default(admin)
  parentId   String? // 邀请人 id
  email      String?
  expiresAt  DateTime
  accepted   Boolean   @default(false)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
}

// 路线（协作 spine）
model Route {
  id            String         @id @default(uuid())
  customerName  String
  customerNameCn String?
  country       String
  agency        String
  destination   String
  groupSize     Int
  travelDate    DateTime?
  statusKey     String
  modeKey       String         @default("collab")
  agencyId      String? // 归属机构（境外旅行社 org id）；用于机构间物理隔绝的查询隔离
  agencyOrg     Agency?        @relation(fields: [agencyId], references: [id], onDelete: SetNull, name: "RouteAgency")
  provincialId  String? // 归属省地接社 org id；一手将该路线分配给某省地接社后，该省地接社通过 H5 参与协作
  provincialOrg Agency?        @relation(fields: [provincialId], references: [id], onDelete: SetNull, name: "RouteProvincial")
  createdById   String
  createdBy     User           @relation(fields: [createdById], references: [id], onDelete: Cascade, name: "RouteCreatedBy")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  versions      RouteVersion[]
  shares        RouteShare[]
}

// 路线版本（行程+报价一体化，每次保存并通知生成新版本）
model RouteVersion {
  id         String   @id @default(uuid())
  routeId    String
  route      Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  version    String
  draft      Boolean  @default(true)
  itinerary  Json
  quote      Json?
  createdAt  DateTime @default(now())
}

// 案例（由已确认路线脱敏派生）
model Case {
  id          String     @id @default(uuid())
  routeId     String?
  destination String
  days        Int
  theme       String
  priceRange  String
  status      CaseStatus @default(draft)
  createdById String
  createdAt   DateTime   @default(now())
  publishedAt DateTime?
}

// 知识库条目
model KbEntry {
  id          String   @id @default(uuid())
  title       String
  category    String
  tags        String[]
  body        String
  routeId     String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 成本询价（一手向省地接社询价，省地接社填写成本价①）
model CostInquiry {
  id           String      @id @default(uuid())
  routeId      String
  provincialId String // 被询价的省地接社机构 org id（原 agencyId 改名，语义更清晰）
  provincialOrg Agency?     @relation(fields: [provincialId], references: [id], onDelete: SetNull, name: "CostInquiryProvincial")
  token        String      @unique
  cost1        Decimal?    @db.Decimal(12, 2) // 省地接社填的成本①（地接成本）合计
  cost2        Decimal?    @db.Decimal(12, 2) // 预留：省地接社次级成本（当前未强制使用）
  costItems    Json?       // 省地接社填写的成本①明细 { name: string, amount: number }[]
  status       String      @default("pending") // pending | submitted
  share        RouteShare? @relation
  createdAt    DateTime    @default(now())
}


// 协作 H5 共享令牌（一手/旅行社分享给客户或对方的只读链接）
model RouteShare {
  id             String        @id @default(uuid())
  token          String        @unique
  routeId        String
  route          Route         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  versionId      String?
  role           Role          @default(agency) // 预览角色：决定 H5 内报价可见性
  public         Boolean       @default(false) // 公开(对客)链接：仅暴露对客价 guestPrice，不泄漏内部成本①/利润
  costInquiryId  String?       @unique // 省地接社协作 H5 关联的成本询价（一个 share 对应一个询价）
  costInquiry    CostInquiry?  @relation(fields: [costInquiryId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  expiresAt      DateTime?
}

// 机构提交链接（PandaKing 预发常驻，机构免登录提交路线初稿）
model RouteIntake {
  id          String   @id @default(uuid())
  token       String   @unique
  agencyId    String                 // 归属机构 org id（钉死，提交时作 Route.agencyId）
  createdById String                 // 发链接的 PandaKing 管理员 id
  expiresAt   DateTime               // 30 天过期
  createdAt   DateTime @default(now())
  @@index([agencyId])
}

// 协作 H5 反馈（客户/对方在链接内提交的修改意见）
model RouteFeedback {
  id         String   @id @default(uuid())
  routeId    String
  versionId  String?
  token      String?  // 关联 RouteShare，便于溯源
  authorName String?
  authorRole String?  // 提交方角色：pandaking / agency / provincial（协作时间线着色与隔离用）
  source     String   @default("h5") // h5=协作H5链接反馈；console=控制台提交（agency/provincial 给一手的建议，或一手回传）
  content    String
  createdAt  DateTime @default(now())
}

// 路线备份历史库（一手删除路线时归档快照，便于审计与恢复溯源）
// 删除为硬删，但删除前整条路线+关联数据快照写入本表，不破坏生产查询隔离。
model RouteArchive {
  id            String   @id @default(uuid())
  routeId       String   // 原路线 id，便于回溯定位
  routeData     Json     // 路线主记录快照
  versions      Json?    // 路线版本（行程+报价）快照数组
  shares        Json?    // 协作 H5 共享令牌快照数组
  feedbacks     Json?    // 协作反馈快照数组
  costInquiries Json?    // 成本询价快照数组
  deletedById   String?  // 删除操作者用户 id（一手）
  deletedByName String?  // 删除操作者名称，便于审计
  reason        String?  // 删除原因（可选）
  createdAt     DateTime @default(now())

  @@index([routeId])
  @@index([createdAt])
}
