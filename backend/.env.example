# 后端环境变量模板（复制为 .env 后填写）
# 本地 Docker Postgres（docker-compose.yml 提供）：
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pandaking9?schema=public"

# 生产/CloudBase Postgres 示例：
# DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<db>?schema=public&sslmode=require"

# 微信 OAuth2（一手 PandaKing 发起邀请时用，部署时再填）
WECHAT_APPID=""
WECHAT_SECRET=""

# JWT 签名（部署时务必改成随机长串）
JWT_SECRET="dev-only-change-me"
