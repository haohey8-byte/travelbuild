# 后端环境变量模板（复制为 .env 后填写）
# ── 数据库：CloudBase Postgres（腾讯云 PostgreSQL 实例） ──
# 从 CloudBase 控制台「数据库 / PostgreSQL」获取连接串，形如：
#   postgresql://<user>:<password>@<host>:5432/<dbname>?schema=public&sslmode=require
# CloudBase Postgres 默认要求 SSL，务必保留 sslmode=require
DATABASE_URL="postgresql://<user>:<password>@<cloudbase-postgres-host>:5432/pandaking9?schema=public&sslmode=require"

# 本地 Docker Postgres（docker-compose.yml 提供，开发用）：
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pandaking9?schema=public"

# 微信 OAuth2（一手 PandaKing 发起邀请时用，部署时再填）
WECHAT_APPID=""
WECHAT_SECRET=""

# JWT 签名（部署时务必改成随机长串）
JWT_SECRET="dev-only-change-me"

# 开发旁路：true 时免 token 注入默认一手用户（便于骨架联调）；部署务必设为 false
DEV_BYPASS_AUTH=true
